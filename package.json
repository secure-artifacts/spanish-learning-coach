{
  "name": "spanish-learning-coach",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "多语言学习教练",
  "description": "多语言学习教练 - 西语学习桌面应用",
  "author": "secure-artifacts",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "postinstall": "node scripts/install-electron.cjs",
    "desktop": "npm run build && electron .",
    "desktop:dev": "cross-env DESKTOP_DEV=1 electron .",
    "pack:win": "npm run build && node scripts/pack.cjs",
    "dist:win": "npm run build && electron-builder --win portable --publish never"
  },
  "build": {
    "appId": "com.secure-artifacts.spanish-learning-coach",
    "productName": "多语言学习教练",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "SpanishLearningCoach-${version}-portable.exe"
    }
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "rcedit": "^4.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
